# =============================================
# Doctor AI Dashboard — Environment Variables
# =============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- ChromaDB ---
CHROMA_HOST=localhost
CHROMA_PORT=8100

# --- LLM APIs ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=

# --- Research ---
PERPLEXITY_API_KEY=

# --- Document Processing ---
KIMI_API_KEY=

# --- CRM (Kommo) ---
KOMMO_TOKEN=                     # JWT long-lived v4 (scopes: crm, files, notifications, ...)
KOMMO_DOMAIN=                    # <subdomain>.kommo.com (no https://, no trailing slash)
KOMMO_INTEGRATION_SECRET=        # OAuth client secret (Settings → Integrations → Private integration)
KOMMO_CHATS_CHANNEL_SECRET=      # Chats custom channel secret (from POST amojo.kommo.com/v2/origin/custom)
KOMMO_THALES_USER_ID=            # Numeric Kommo user ID (matches JWT `sub`)
KOMMO_INTEGRATION_ID=            # UUID of the integration (matches JWT `aud`)
KOMMO_ACCOUNT_ID=                # Numeric Kommo account ID (from JWT)

# --- WhatsApp Cloud API (Meta Graph API) — Dual WABA ---
# DAP runs two WABAs in two separate Meta Apps (dap_prime + dap_bosch). Each
# brand has its own {phone_number_id, access_token, app_secret, verify_token,
# waba_id}. Webhook URLs in Meta must point to:
#   https://<public>/api/meta/webhook/dap_prime
#   https://<public>/api/meta/webhook/dap_bosch
# The brand in the path is what the gateway uses to pick the app_secret for
# HMAC verification. See META_SETUP_GUIDE.md.
#
# Convention: META_<FIELD>_<BRAND_UPPER>. Legacy un-suffixed vars below are
# accepted ONLY as a fallback for the default brand (KOMMO_DEFAULT_BRAND,
# default "dap_prime"). Prefer the scoped ones in new deployments.

# dap_prime (linha principal — Doctor Auto Prime)
META_PHONE_NUMBER_ID_DAP_PRIME=
META_ACCESS_TOKEN_DAP_PRIME=
META_APP_SECRET_DAP_PRIME=
META_VERIFY_TOKEN_DAP_PRIME=
META_WABA_ID_DAP_PRIME=

# dap_bosch (Bosch Car Service — Doctor Bosch Service)
META_PHONE_NUMBER_ID_DAP_BOSCH=
META_ACCESS_TOKEN_DAP_BOSCH=
META_APP_SECRET_DAP_BOSCH=
META_VERIFY_TOKEN_DAP_BOSCH=
META_WABA_ID_DAP_BOSCH=

# Brand routing fallback (matches KOMMO_DEFAULT_BRAND for consistency)
KOMMO_DEFAULT_BRAND=dap_prime

# Legacy single-tenant envs — DEPRECATED. Kept so existing prod boxes boot
# until the dual-WABA cutover completes. Used only for the default brand
# when the scoped envs above are unset. Remove after migration.
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_WABA_ID=

# --- OpenClaw ---
OPENCLAW_URL=
OPENCLAW_TOKEN=

# --- Gateway ---
GATEWAY_PORT=3001
PYTHON_SERVICE_URL=http://127.0.0.1:8000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173

# --- Auth ---
# Service-to-service token. Set to any random string for local dev so the
# socket.io + HTTP middleware accept your gateway/dashboard requests.
API_SECRET=

# Local-only escape hatch: when set to 1 AND NODE_ENV is not "production",
# any non-empty token is accepted as { id: 'anonymous-dev' }. The flag is
# silently ignored in production. Use this if you want to run the dashboard
# locally without provisioning Supabase Auth or an API_SECRET.
# ALLOW_ANONYMOUS_DEV=1

# --- Obsidian ---
VAULT_PATH=

# --- Logging ---
LOG_LEVEL=info

# --- Docker ---
# Override default ports when running via docker compose
# CHROMA_PORT=8100       (maps host port to internal 8000)
# GATEWAY_PORT=3001      (maps host port to internal 3001)

# --- Cloudflare Tunnel (production deploy) ---
# Generate a tunnel token at: https://one.dash.cloudflare.com/ → Networks → Tunnels → Create
CLOUDFLARE_TUNNEL_TOKEN=     # eyJhIjoi... (long base64 string)
PUBLIC_DOMAIN=               # e.g. doctor.example.com — used for webhook URL hints
