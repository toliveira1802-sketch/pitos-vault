diff --git a/gateway/src/services/realtime.ts b/gateway/src/services/realtime.ts
index 10a8dbe..d28dc79 100644
--- a/gateway/src/services/realtime.ts
+++ b/gateway/src/services/realtime.ts
@@ -160,3 +160,36 @@ export function emitAnnaEscalated(ev: AnnaEscalatedEvent): void {
   if (!io) return;
   io.to("admin").emit("anna:escalated", ev);
 }
+
+// ---------- Anna shadow-mode draft events ----------
+
+export interface AnnaDraftEvent {
+  draftId: string;
+  brandId: string;
+  conversationId?: string;
+  clientPhone: string;
+  clientName?: string | null;
+  inboundText?: string;
+  annaText?: string;
+  annaIntent?: string | null;
+  at: string;
+}
+
+/**
+ * Notify chairman that Anna produced a draft awaiting review.
+ * Dashboard component AnnaDraftQueue subscribes via the `admin` room.
+ */
+export function emitAnnaDraftNew(ev: AnnaDraftEvent): void {
+  if (!io) return;
+  io.to("admin").emit("anna:draft:new", ev);
+}
+
+export function emitAnnaDraftSent(ev: { draftId: string; brandId: string; sentMessageId: string; at: string }): void {
+  if (!io) return;
+  io.to("admin").emit("anna:draft:sent", ev);
+}
+
+export function emitAnnaDraftRejected(ev: { draftId: string; brandId: string; reason: string | null; at: string }): void {
+  if (!io) return;
+  io.to("admin").emit("anna:draft:rejected", ev);
+}
